rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isWriter() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    match /raw_customers/{customerId} {
      allow read: if isAuthenticated();
      allow create, update: if isWriter()
        && request.resource.data.keys().hasAll(['id', 'name', 'email', 'is_active', 'updated_at']);
      allow delete: if false;
    }

    match /raw_stores/{storeId} {
      allow read: if isAuthenticated();
      allow create, update: if isWriter()
        && request.resource.data.keys().hasAll(['id', 'name', 'tax_rate', 'opened_at', 'is_active', 'updated_at']);
      allow delete: if false;
    }

    match /raw_products/{sku} {
      allow read: if isAuthenticated();
      allow create, update: if isWriter()
        && request.resource.data.keys().hasAll(['sku', 'name', 'type', 'unit_price', 'is_active', 'updated_at']);
      allow delete: if false;
    }

    match /raw_supplies/{supplyId} {
      allow read: if isAuthenticated();
      allow create, update: if isWriter()
        && request.resource.data.keys().hasAll(['id', 'sku', 'name', 'cost', 'perishable', 'updated_at']);
      allow delete: if false;
    }

    match /raw_orders/{orderId} {
      allow read: if isAuthenticated();
      allow create, update: if isWriter()
        && request.resource.data.keys().hasAll([
          'id',
          'customer_id',
          'store_id',
          'subtotal',
          'tax_paid',
          'order_total',
          'ordered_at',
          'status',
          'channel',
          'updated_at'
        ]);
      allow delete: if false;
    }

    match /raw_items/{itemId} {
      allow read: if isAuthenticated();
      allow create, update: if isWriter()
        && request.resource.data.keys().hasAll([
          'id',
          'order_id',
          'sku',
          'quantity',
          'unit_price',
          'line_total',
          'updated_at'
        ]);
      allow delete: if false;
    }

    match /customer_stats/{customerId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /app_state/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
